{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "target": "ES2020",
    "useDefineForClassFields": true
  },
  "include": ["src/types", "src/lib/mockData.ts", "src/lib/api.ts", "src/lib/cellStatus.ts", "src/components/ui", "src/components/AppShell.tsx", "src/components/cells", "src/pages/ProcedureViewer.tsx", "src/App.tsx", "src/main.tsx", "src/lib/utils.ts", "src/index.css", "src/vite-env.d.ts"]
}
